# Confluence Page MCP — Environment Configuration
# Copy this to .env or set these in your MCP client's env config.
# For MCP clients (Claude Desktop, Cline, etc.), set these in mcpServers.<name>.env

CONFLUENCE_BASE_URL=https://confluence.yourcompany.com
CONFLUENCE_USERNAME=your-email@example.com
CONFLUENCE_TOKEN=your-api-token-or-password
